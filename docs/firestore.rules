rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function normalizedEmail() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function isActiveMemberByEmailKey(emailKey, bossUid) {
      return emailKey != ''
        && exists(/databases/$(database)/documents/member_lookup/$(emailKey))
        && get(/databases/$(database)/documents/member_lookup/$(emailKey)).data.bossUid == bossUid
        && get(/databases/$(database)/documents/member_lookup/$(emailKey)).data.ativo == true;
    }

    function isActiveMemberByEmail(bossUid) {
      let emailKey = normalizedEmail();
      return isActiveMemberByEmailKey(emailKey, bossUid);
    }

    function isActiveMemberByUid(bossUid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/member_uid_lookup/$(request.auth.uid))
        && get(/databases/$(database)/documents/member_uid_lookup/$(request.auth.uid)).data.bossUid == bossUid
        && get(/databases/$(database)/documents/member_uid_lookup/$(request.auth.uid)).data.ativo != false;
    }

    function isActiveMemberOf(bossUid) {
      return isActiveMemberByEmail(bossUid) || isActiveMemberByUid(bossUid);
    }

    function isBoss(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function canAccessUserData(userId) {
      return request.auth != null && (
        isBoss(userId) || isActiveMemberOf(userId)
      );
    }

    match /member_lookup/{emailKey} {
      allow read: if request.auth != null && (
        normalizedEmail() == emailKey
        || resource.data.bossUid == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.bossUid == request.auth.uid;
      allow update: if request.auth != null && (
        request.resource.data.bossUid == request.auth.uid
        || (
          normalizedEmail() == emailKey
          && resource.data.ativo == true
          && request.resource.data.bossUid == resource.data.bossUid
          && request.resource.data.ativo == resource.data.ativo
        )
      );
      allow delete: if request.auth != null && resource.data.bossUid == request.auth.uid;
    }

    match /member_uid_lookup/{memberUid} {
      allow read: if request.auth != null && (
        request.auth.uid == memberUid
        || resource.data.bossUid == request.auth.uid
      );
      allow create, update: if request.auth != null
        && request.auth.uid == memberUid
        && request.resource.data.bossUid is string
        && request.resource.data.ativo == true
        && (
          isActiveMemberByEmail(request.resource.data.bossUid)
          || (
            request.resource.data.email is string
            && isActiveMemberByEmailKey(request.resource.data.email, request.resource.data.bossUid)
          )
        );
      allow delete: if request.auth != null && resource.data.bossUid == request.auth.uid;
    }

    match /users/{userId}/emails_autorizados/{emailDoc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/cadastros/{docId} {
      allow read, write: if canAccessUserData(userId);
    }

    match /users/{userId}/sessoes/{docId} {
      allow read, write: if canAccessUserData(userId);
    }

    match /users/{userId}/cadastro_rubricas/{docId} {
      allow read, write: if canAccessUserData(userId);
    }

    match /users/{userId}/sessao_rubricas/{docId} {
      allow read, write: if canAccessUserData(userId);
    }

    match /users/{userId}/aplicadores/{docId} {
      allow read: if canAccessUserData(userId);
      allow create, delete: if isBoss(userId);
      // Membros autorizados podem alterar apenas a senha (senhaHash);
      // identidade (nip/nome/categoria) permanece inalterada.
      allow update: if isBoss(userId) || (
        isActiveMemberOf(userId)
        && request.resource.data.nip == resource.data.nip
        && request.resource.data.nome == resource.data.nome
        && request.resource.data.categoria == resource.data.categoria
      );
    }

    match /users/{userId}/pre_cadastros/{docId} {
      allow read, write: if canAccessUserData(userId);
    }

    match /users/{userId}/system/{docId} {
      allow read: if canAccessUserData(userId);
      allow write: if isBoss(userId);
    }

    // Probe de relógio — drift de horário na sincronização (qualquer usuário autenticado).
    match /_sync_probe/clock {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly(['probe'])
        && request.resource.data.probe == request.time;
    }
  }
}
